# Переменные окружения для разработки
# Скопируйте этот файл в .env и настройте под вашу среду

# Приложение
APP_NAME=Local Messenger
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=messenger
DB_USER=messenger_user
DB_PASSWORD=secure_password

# MinIO (объектное хранилище)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media
MINIO_SECURE=false

# JWT настройки
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# TOTP (2FA)
TOTP_ISSUER=Local Messenger
TOTP_ALGORITHM=SHA1
TOTP_DIGITS=6
TOTP_PERIOD=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Логирование
LOG_LEVEL=INFO
